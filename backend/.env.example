# TinBoker Backend Service Configuration
# ==========================================
# Copy this file to .env and adjust the values for your environment.

# ==================== Google Cloud Platform ====================
# GCP Project ID - REQUIRED for Secret Manager and Cloud SQL
GCP_PROJECT_ID=gen-lang-client-0901363254

# Service Account Key (for Secret Manager access)
# On VPS, this should point to the deployed key file
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-service-account.json

# ==================== Secrets (from Google Secret Manager) ====================
# These secrets are loaded from GCP Secret Manager at runtime.
# Only set these in .env if you need to OVERRIDE GSM for local development.
#
# GSM Secrets used:
#   - POSTGRES_PASSWORD: Cloud SQL password
#   - ADMIN_PASSWORD: Admin UI login password
#   - ADMIN_JWT_SECRET: JWT signing key for admin tokens
#   - FINMIND_API_KEY: FinMind API access
#   - MASSIVE_API_KEY: Massive API access
#   - JWT_SECRET_KEY: User authentication JWT

# For local development without GSM:
# FINMIND_API_KEY=your_finmind_api_key_here
# MASSIVE_API_KEY=your_massive_api_key_here
# ADMIN_PASSWORD=local_dev_password
# ADMIN_JWT_SECRET=local_dev_secret

# ==================== Database ====================

# SQLite (Default for local development)
DATABASE_PATH=data/tinboker.db
USE_POSTGRES=false

# PostgreSQL (VPS via docker-compose `postgres` service)
# The compose files (docker-compose.yml + overrides) wire backend → postgres
# automatically using POSTGRES_HOST=postgres, USER=podcast_user, DB=podcast_db.
#
# POSTGRES_PASSWORD is NOT stored on disk. It's fetched from GSM at deploy time
# by .github/workflows/backend-deploy.yml and passed to the VPS via the SSH
# session env, where docker-compose interpolates ${POSTGRES_PASSWORD} for the
# postgres container. The backend itself reads the same GSM secret via
# config_loader (Settings field: postgres_password).


# ==================== Redis (Caching) ====================

# Local Development (Docker)
REDIS_URL=redis://localhost:6379/0

# VPS Production (Docker Compose internal network)
# REDIS_URL=redis://redis:6379/0

# ==================== Server Configuration ====================

HOST=0.0.0.0
PORT=5174
ENVIRONMENT=development
# Options: development, staging, production
# Note: production forces USE_POSTGRES=true

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,https://tinboker.com,https://dev.tinboker.com

# ==================== Google OAuth ====================

# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==================== JWT (User Auth) ====================

# JWT_SECRET_KEY loaded from GSM, or set locally:
# JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== WebSocket ====================

WEBSOCKET_UPDATE_INTERVAL=5
INTRADAY_SNAPSHOT_RETENTION_DAYS=30

# ==================== External APIs ====================

# Netcup Podcast API (internal)
# NETCUP_IP=http://159.195.45.195:8000
